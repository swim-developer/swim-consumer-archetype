## Testing Patterns

### Integration Testing with Testcontainers

**Pattern**: Spin up real dependencies for tests

**Maven Dependency**:
```xml
<dependency>
    <groupId>org.testcontainers</groupId>
    <artifactId>testcontainers</artifactId>
    <version>1.19.0</version>
    <scope>test</scope>
</dependency>
<dependency>
    <groupId>org.testcontainers</groupId>
    <artifactId>postgresql</artifactId>
    <version>1.19.0</version>
    <scope>test</scope>
</dependency>
```

**Test Class**:
```java
@QuarkusTest
@TestProfile(BrokerTestProfile.class)
public class DnotamPublisherTest {
    
    @Container
    static GenericContainer<?> artemis = new GenericContainer<>("quay.io/artemiscloud/activemq-artemis-broker:latest")
        .withExposedPorts(5672, 8161)
        .withEnv("AMQ_USER", "admin")
        .withEnv("AMQ_PASSWORD", "admin");
    
    @Test
    public void testPublishDnotam() {
        given()
            .contentType(ContentType.JSON)
            .body(dnotamEvent)
        .when()
            .post("/publish")
        .then()
            .statusCode(200);
        
        // Verify message in broker
        assertThat(receivedMessages).hasSize(1);
    }
}
```

---

### Contract Testing Pattern

**Purpose**: Verify API compatibility between services

**Pact Example** (Consumer side):
```java
@PactTestFor(providerName = "subscription-manager")
public class SubscriptionManagerContractTest {
    
    @Pact(consumer = "dnotam-consumer")
    public RequestResponsePact createSubscription(PactDslWithProvider builder) {
        return builder
            .given("topics exist")
            .uponReceiving("a request to create subscription")
                .path("/subscriptions")
                .method("POST")
                .body(new PactDslJsonBody()
                    .stringType("topic_name", "notam.EBBR")
                    .stringType("queue_name", "dnotam-consumer.notam.EBBR"))
            .willRespondWith()
                .status(201)
                .body(new PactDslJsonBody()
                    .uuid("id")
                    .stringValue("topic_name", "notam.EBBR"))
            .toPact();
    }
    
    @Test
    @PactTestFor(pactMethod = "createSubscription")
    public void testCreateSubscription(MockServer mockServer) {
        SubscriptionManagerClient client = new SubscriptionManagerClient(mockServer.getUrl());
        Subscription subscription = client.createSubscription("notam.EBBR", "dnotam-consumer.notam.EBBR");
        
        assertThat(subscription.getId()).isNotNull();
        assertThat(subscription.getTopicName()).isEqualTo("notam.EBBR");
    }
}
```

