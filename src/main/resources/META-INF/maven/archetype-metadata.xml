<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor
        xmlns="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0
        https://maven.apache.org/xsd/archetype-descriptor-1.1.0.xsd"
        name="swim-consumer-archetype">

    <requiredProperties>
        <requiredProperty key="serviceName">
            <defaultValue>myservice</defaultValue>
        </requiredProperty>
        <requiredProperty key="serviceDisplayName">
            <defaultValue>My Service</defaultValue>
        </requiredProperty>
        <requiredProperty key="servicePrefix">
            <defaultValue>Myservice</defaultValue>
        </requiredProperty>
        <requiredProperty key="dataModel">
            <defaultValue>FIXM</defaultValue>
        </requiredProperty>
        <requiredProperty key="collectionPrefix">
            <defaultValue>myservice</defaultValue>
        </requiredProperty>
        <!-- REQUIRED: no default. Examples: swim-aixm-model | swim-fixm-model-ed254 | swim-fixm-ffice-model -->
        <requiredProperty key="modelArtifactId"/>
    </requiredProperties>

    <fileSets>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
            <directory>src/main/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
            <directory>src/main/resources</directory>
            <includes>
                <include>**/*.properties</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
            <directory>src/test/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <includes>
                <include>mvnw</include>
                <include>mvnw.cmd</include>
            </includes>
        </fileSet>
        <fileSet filtered="false">
            <directory>.mvn</directory>
            <includes>
                <include>wrapper/maven-wrapper.properties</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" encoding="UTF-8">
            <directory></directory>
            <includes>
                <include>Makefile</include>
            </includes>
        </fileSet>
    </fileSets>
</archetype-descriptor>
